# Production build-time env (loaded automatically by Vite on `vite build`).
#
# VITE_SERVER_URL — the multiplayer server origin the client connects to when
# the player clicks "Play Online (FFA)". Points at the Fly.io deployment.
# This is NOT a secret: it's a public URL the browser connects to, and Vite
# inlines it into the shipped bundle anyway. Committed so Vercel's build picks
# it up (overrides the repo's .gitignore .env.* rule via .gitignore negation).
VITE_SERVER_URL=https://ilcartigo-game.fly.dev
