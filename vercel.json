{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "bash ./build-static.sh",
  "outputDirectory": "public",
  "installCommand": "cd client && npm install",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/play/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
